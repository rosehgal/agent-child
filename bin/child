#!/usr/bin/env bash
#
# child — fork the current agent session into a tmux split pane.
#
# Spawns a child agent (a forked Claude session by default, or gemini / codex /
# any command) in a tmux pane. Every child pane runs a watchdog tied to the
# main agent's PID: when the main agent exits, all of its child panes (and the
# tmux session `child` created for them, if any) are killed automatically.
#
# Usage:
#   child [options] [--] [prompt for the child agent...]
#
# Options:
#   --agent <name>     claude (default) | gemini | codex | any CLI on PATH
#   --cmd "<command>"  run an arbitrary command instead of an agent CLI
#   --session <uuid>   Claude session ID to fork (default: auto-detect)
#   --no-fork          for claude: start a fresh session, don't fork this one
#   -H, --horizontal   force a side-by-side split (columns) for this child
#   -V, --vertical     force a stacked split (rows) for this child
#                      (default: auto-pick direction, then tidy into an even grid)
#   --dangerously-skip-permissions      force the child claude to skip permission
#                                        prompts (auto-detected from the parent by default)
#   --no-dangerously-skip-permissions   never pass the skip-permissions flag,
#                                        even if the parent was started with it
#   --main-pid <pid>   override the PID the children's lifetime is tied to
#   --open             if not inside tmux, open a terminal attached to the session
#   --list             list live child panes for this main agent
#   --killall          kill all child panes for this main agent
#   --update           update agent-child to the latest version from GitHub
#   -h, --help         show this help
#
# Examples:
#   child "run the test suite and fix failures"     # fork claude into a pane
#   child --agent gemini "review src/ for bugs"
#   child --cmd "npm run dev"
set -euo pipefail

RUNDIR="${HOME}/.cache/agent-child"
mkdir -p "$RUNDIR"

usage() { sed -n '2,/^set -euo/p' "$0" | sed '$d' | sed 's/^# \{0,1\}//'; }

if ! command -v tmux >/dev/null 2>&1; then
  echo "child: tmux is required but not installed (brew install tmux / apt install tmux)" >&2
  exit 1
fi

AGENT="claude"
RAW_CMD=""
SESSION_ID="${CLAUDE_SESSION_ID:-}"
NO_FORK=0
MAIN_PID=""
OPEN_TERMINAL=0
ACTION="spawn"
# auto = inherit from the parent agent; 1 = force on; 0 = force off
SKIP_PERMISSIONS="auto"
# "" = auto (aspect-ratio) + tiled rebalance; h = side-by-side; v = stacked
SPLIT_DIR=""
PROMPT_ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    --agent)    AGENT="$2"; shift 2 ;;
    --cmd)      RAW_CMD="$2"; shift 2 ;;
    --session)  SESSION_ID="$2"; shift 2 ;;
    --no-fork)  NO_FORK=1; shift ;;
    -H|--horizontal) SPLIT_DIR="h"; shift ;;
    -V|--vertical)   SPLIT_DIR="v"; shift ;;
    --dangerously-skip-permissions)    SKIP_PERMISSIONS=1; shift ;;
    --no-dangerously-skip-permissions) SKIP_PERMISSIONS=0; shift ;;
    --main-pid) MAIN_PID="$2"; shift 2 ;;
    --open)     OPEN_TERMINAL=1; shift ;;
    --list)     ACTION="list"; shift ;;
    --killall)  ACTION="killall"; shift ;;
    --update)   ACTION="update"; shift ;;
    -h|--help)  usage; exit 0 ;;
    --)         shift; PROMPT_ARGS+=("$@"); break ;;
    *)          PROMPT_ARGS+=("$1"); shift ;;
  esac
done

if [ "$ACTION" = "update" ]; then
  echo "updating agent-child from GitHub..."
  curl -fsSL https://raw.githubusercontent.com/rosehgal/agent-child/main/install.sh | bash
  exit 0
fi

# ---------------------------------------------------------------------------
# Find the main agent process: walk up the process ancestry looking for a
# known agent CLI. Children's lifetime is tied to this PID. Falls back to the
# invoking shell, so `child` from a bare terminal ties children to that shell.
# ---------------------------------------------------------------------------
is_agent_proc() {
  local first second
  first=$(basename "${1%% *}")
  second=$(echo "$1" | awk '{print $2}')
  case "$first" in
    claude|gemini|codex|cursor-agent|aider|copilot|amp|goose) return 0 ;;
    node|bun|deno)
      case "$(basename "${second:-x}")" in
        claude*|gemini*|codex*|aider*) return 0 ;;
      esac ;;
  esac
  return 1
}

find_main_pid() {
  local pid=$$ cmdline
  while [ "$pid" -gt 1 ]; do
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ') || break
    [ -n "$pid" ] && [ "$pid" -gt 1 ] || break
    cmdline=$(ps -o command= -p "$pid" 2>/dev/null) || break
    if is_agent_proc "$cmdline"; then echo "$pid"; return 0; fi
  done
  echo "$PPID"
}

[ -n "$MAIN_PID" ] || MAIN_PID=$(find_main_pid)
PANES_FILE="$RUNDIR/panes-$MAIN_PID"
CHILD_SESSION="child-$MAIN_PID"

# ---------------------------------------------------------------------------
# Inherit permission mode. If the parent agent actually bypasses permission
# prompts (`--dangerously-skip-permissions`), the child should too — otherwise
# a forked/fresh child silently drops back to prompting. We resolve it from, in
# order: an explicit --[no-]dangerously-skip-permissions flag, a marker env var
# we propagate to descendants (tmux panes don't keep process ancestry, so
# grandchildren can't sniff the flag directly), then the main agent's own
# command line.
#
# NOTE: only `--dangerously-skip-permissions` puts the parent in bypass mode.
# `--allow-dangerously-skip-permissions` merely makes bypass *available* without
# enabling it, so the parent still prompts — we must NOT treat it as bypass, or
# children would skip prompts the parent doesn't. The leading space in the glob
# keeps `--allow-...` from matching `--dangerously-...` as a substring.
# ---------------------------------------------------------------------------
resolve_skip_permissions() {
  if [ "${CHILD_SKIP_PERMISSIONS:-}" = "1" ]; then echo 1; return; fi
  local cmd
  cmd=$(ps -o command= -p "$MAIN_PID" 2>/dev/null || true)
  case "$cmd" in
    *\ --dangerously-skip-permissions*) echo 1; return ;;
  esac
  echo 0
}
if [ "$SKIP_PERMISSIONS" = "auto" ]; then SKIP_PERMISSIONS=$(resolve_skip_permissions); fi

SKIP_FLAG=""
WRAPPER_ENV=""
if [ "$SKIP_PERMISSIONS" = "1" ]; then
  SKIP_FLAG=" --dangerously-skip-permissions"
  WRAPPER_ENV="export CHILD_SKIP_PERMISSIONS=1"   # so nested children inherit it
fi

# ---------------------------------------------------------------------------
# list / killall
# ---------------------------------------------------------------------------
live_panes() {
  [ -f "$PANES_FILE" ] || return 0
  local pane
  while IFS= read -r pane; do
    tmux display-message -p -t "$pane" \
      '#{pane_id} #{session_name}:#{window_index}.#{pane_index} #{pane_current_command}' \
      2>/dev/null || true
  done < "$PANES_FILE"
}

if [ "$ACTION" = "list" ]; then
  out=$(live_panes)
  if [ -n "$out" ]; then echo "$out"; else echo "no live child panes for main pid $MAIN_PID"; fi
  exit 0
fi

if [ "$ACTION" = "killall" ]; then
  if [ -f "$PANES_FILE" ]; then
    while IFS= read -r pane; do tmux kill-pane -t "$pane" 2>/dev/null || true; done < "$PANES_FILE"
    rm -f "$PANES_FILE"
  fi
  tmux kill-session -t "$CHILD_SESSION" 2>/dev/null || true
  echo "killed all children of main pid $MAIN_PID"
  exit 0
fi

# ---------------------------------------------------------------------------
# Build the child agent command
# ---------------------------------------------------------------------------
detect_claude_session() {
  # Claude Code stores transcripts under a slug of the directory the session
  # was launched from; the newest transcript there is the running session.
  # The agent may have cd'd deeper, so walk up from $PWD until a match.
  local dir="$PWD" slug pdir
  while [ -n "$dir" ]; do
    slug=$(printf '%s' "$dir" | sed 's/[^a-zA-Z0-9]/-/g')
    pdir="$HOME/.claude/projects/$slug"
    if [ -d "$pdir" ]; then
      ls -t "$pdir"/*.jsonl 2>/dev/null | head -1 | xargs -I{} basename {} .jsonl
      return 0
    fi
    [ "$dir" = "/" ] && break
    dir=$(dirname "$dir")
  done
}

PROMPT=""
if [ ${#PROMPT_ARGS[@]} -gt 0 ]; then PROMPT="${PROMPT_ARGS[*]}"; fi

# FORKING marks the case that can fail at runtime (resuming the *current* live
# session) and needs a fresh-session fallback; FALLBACK_CMD is that fallback.
FORKING=0
FALLBACK_CMD=""

if [ -n "$RAW_CMD" ]; then
  CHILD_CMD="$RAW_CMD"
elif [ "$AGENT" = "claude" ]; then
  if [ "$NO_FORK" -eq 0 ]; then
    [ -n "$SESSION_ID" ] || SESSION_ID=$(detect_claude_session)
  fi
  if [ -n "$SESSION_ID" ] && [ "$NO_FORK" -eq 0 ]; then
    CHILD_CMD="claude --resume $(printf '%q' "$SESSION_ID") --fork-session${SKIP_FLAG}"
    FORKING=1
    FALLBACK_CMD="claude${SKIP_FLAG}"
  else
    CHILD_CMD="claude${SKIP_FLAG}"
  fi
  if [ -n "$PROMPT" ]; then
    CHILD_CMD="$CHILD_CMD $(printf '%q' "$PROMPT")"
    [ "$FORKING" -eq 1 ] && FALLBACK_CMD="$FALLBACK_CMD $(printf '%q' "$PROMPT")"
  fi
else
  CHILD_CMD="$AGENT"
  [ -n "$PROMPT" ] && CHILD_CMD="$CHILD_CMD $(printf '%q' "$PROMPT")"
fi

# ---------------------------------------------------------------------------
# Pane wrapper: a background watchdog kills the pane when the main agent
# dies; the child agent runs in the foreground so the pane closes when the
# agent exits on its own.
#
# Forking the CURRENT session is the common case, and it can fail: Claude Code
# won't `--resume` a conversation that is still live (the session you invoked
# /child from), so it prints "No conversation found with session ID: …" and
# exits non-zero within a second. With a plain `exec` the pane would then just
# vanish, leaving no clue why. So for the fork case we don't exec — we run the
# fork, and if it dies fast with a non-zero status we fall back to a fresh child
# session so the pane always opens. The 8s guard distinguishes that startup
# failure from a session the user actually worked in and then quit (which runs
# longer and must NOT relaunch).
# ---------------------------------------------------------------------------
find "$RUNDIR" -name 'pane-*.sh' -mtime +1 -delete 2>/dev/null || true
WRAPPER="$RUNDIR/pane-$$-$RANDOM.sh"
if [ "$FORKING" -eq 1 ]; then
  cat > "$WRAPPER" <<EOF
#!/usr/bin/env bash
$WRAPPER_ENV
(
  while kill -0 $MAIN_PID 2>/dev/null; do sleep 2; done
  tmux kill-pane -t "\$TMUX_PANE" 2>/dev/null
) &
start=\$SECONDS
$CHILD_CMD
code=\$?
if [ "\$code" -ne 0 ] && [ \$(( SECONDS - start )) -lt 8 ]; then
  printf '\n\033[33m[child] could not fork the current session (it is live and not resumable yet) — starting a fresh child session instead.\033[0m\n' >&2
  exec $FALLBACK_CMD
fi
EOF
else
  cat > "$WRAPPER" <<EOF
#!/usr/bin/env bash
$WRAPPER_ENV
(
  while kill -0 $MAIN_PID 2>/dev/null; do sleep 2; done
  tmux kill-pane -t "\$TMUX_PANE" 2>/dev/null
) &
exec $CHILD_CMD
EOF
fi
chmod +x "$WRAPPER"

# ---------------------------------------------------------------------------
# Spawn the pane — smart split:
#   * always split the LARGEST pane in the window, so repeated /child calls
#     produce a balanced, visually appealing layout instead of slivers
#   * always exactly 50-50
#   * direction: -H forces side-by-side, -V forces stacked; otherwise auto —
#     wide pane -> side-by-side split, tall pane -> stacked split (terminal
#     cells are ~2x taller than wide, so compare width against 2*height)
#
# After the split we rebalance the WHOLE window with tmux's own even layouts.
# A bare sequence of 50/50 splits leaves a staircase of half-of-a-half panes
# once you nest or spawn several children; select-layout redistributes every
# pane evenly so the window stays a clean grid no matter how many/how nested:
#   * -H -> even-horizontal (equal columns)
#   * -V -> even-vertical   (equal rows)
#   * auto -> tiled         (balanced grid)
# ---------------------------------------------------------------------------
smart_split() {
  local window="$1" target w h dir layout pane
  read -r target w h < <(tmux list-panes -t "$window" -F '#{pane_id} #{pane_width} #{pane_height}' \
    | awk '{ a = $2 * $3; if (a > max) { max = a; line = $0 } } END { print line }')
  case "$SPLIT_DIR" in
    h) dir="-h"; layout="even-horizontal" ;;
    v) dir="-v"; layout="even-vertical" ;;
    *) layout="tiled"
       if [ "${w:-0}" -gt $(( ${h:-0} * 2 )) ]; then dir="-h"; else dir="-v"; fi ;;
  esac
  pane=$(tmux split-window "$dir" -l '50%' -d -P -F '#{pane_id}' -t "$target" -c "$PWD" "bash $WRAPPER")
  tmux select-layout -t "$window" "$layout" >/dev/null 2>&1 || true
  printf '%s\n' "$pane"
}

if [ -n "${TMUX:-}" ]; then
  # Already inside tmux: split the current window; keep focus on the main pane.
  PANE_ID=$(smart_split "$(tmux display-message -p '#{window_id}')")
  echo "$PANE_ID" >> "$PANES_FILE"
  echo "child agent started in pane $PANE_ID (main pid $MAIN_PID)"
else
  # Not inside tmux: keep children in a dedicated session the user can attach to.
  if tmux has-session -t "$CHILD_SESSION" 2>/dev/null; then
    PANE_ID=$(smart_split "$CHILD_SESSION")
  else
    tmux new-session -d -s "$CHILD_SESSION" -c "$PWD" "bash $WRAPPER"
    PANE_ID=$(tmux display-message -p -t "$CHILD_SESSION" '#{pane_id}')
  fi
  echo "$PANE_ID" >> "$PANES_FILE"
  echo "child agent started in tmux session '$CHILD_SESSION' pane $PANE_ID (main pid $MAIN_PID)"
  echo "view it with:  tmux attach -t $CHILD_SESSION"
  if [ "$OPEN_TERMINAL" -eq 1 ] && command -v osascript >/dev/null; then
    osascript -e "tell application \"Terminal\" to do script \"tmux attach -t $CHILD_SESSION\"" >/dev/null
    osascript -e 'tell application "Terminal" to activate' >/dev/null 2>&1 || true
  fi
fi

echo "command: $CHILD_CMD"
